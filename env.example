# ===========================================
# CONFIGURAÇÕES DO SISTEMA DE PAGAMENTOS
# ===========================================

# Gateway de pagamento ativo (syncpay ou pushinpay)
GATEWAY=pushinpay

# Ambiente (production ou development)
ENVIRONMENT=production

# Gerar QR Code no mobile (true/false)
GENERATE_QR_CODE_ON_MOBILE=false

# ===========================================
# CONFIGURAÇÕES SYNCPAY
# ===========================================

# Credenciais do SyncPay
SYNCPAY_CLIENT_ID=708ddc0b-357d-4548-b158-615684caa616
SYNCPAY_CLIENT_SECRET=c08d40e5-3049-48c9-85c0-fd3cc6ca502c

# ===========================================
# CONFIGURAÇÕES PUSHINPAY
# ===========================================

# Token do PushinPay
PUSHINPAY_TOKEN=45135|XFE5jjzsKTBY4PN1RXFIe7EISDX2DEHFukqMfii897180772

# ===========================================
# CONFIGURAÇÕES DE WEBHOOK
# ===========================================

# URL base para webhooks
WEBHOOK_BASE_URL=https://privacy-sync.vercel.app

# Chave secreta para validação de webhooks
WEBHOOK_SECRET=sua-chave-secreta-aqui

# ===========================================
# CONFIGURAÇÕES DO MODELO
# ===========================================

# Nome da modelo
MODEL_NAME=Stella Beghini

# Handle da modelo (com ou sem @)
MODEL_HANDLE=@stella_beghini

# Bio da modelo
MODEL_BIO=Com apenas 21 aninhos fui coroada como a bucetinha mais rosa e o cuzinho mais apertado do 🇧🇷. Aqui você assiste minhas surubas, leitadas violentas, sexo anal sem dó e vídeos quentes que não mostro em lugar nenhum. 😈🔥

# ===========================================
# CONFIGURAÇÕES DOS PLANOS
# ===========================================

# Plano Mensal
PLAN_MONTHLY_BUTTON_ID=btn-1-mes
PLAN_MONTHLY_LABEL=1 mês
PLAN_MONTHLY_PRICE_LABEL=R$ 19,90
PLAN_MONTHLY_PRICE=19.90
PLAN_MONTHLY_DESCRIPTION=Assinatura mensal

# Plano Trimestral
PLAN_QUARTERLY_BUTTON_ID=btn-3-meses
PLAN_QUARTERLY_LABEL=3 meses (30% off)
PLAN_QUARTERLY_PRICE_LABEL=R$ 59,70
PLAN_QUARTERLY_PRICE=59.70
PLAN_QUARTERLY_DESCRIPTION=Assinatura trimestral

# Plano Semestral
PLAN_SEMESTRIAL_BUTTON_ID=btn-6-meses
PLAN_SEMESTRIAL_LABEL=6 meses (40% off)
